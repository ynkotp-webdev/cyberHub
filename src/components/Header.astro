---
const { title } = Astro.props;
import '../styles/global.css';
---
<header class="sticky top-0 z-50 bg-black/95 backdrop-blur border-b border-zinc-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href="/cyberHub/" class="flex items-center text-2xl md:text-3xl font-extrabold tracking-tight leading-none">
            <span class="text-white">Сyber</span><span class="bg-orange-500 text-black px-2 py-0.5 rounded-md ml-1">Hub</span>
        </a>

        <nav class="hidden md:flex gap-6 text-sm font-medium">
            <a href="#features" class="hover:text-orange-500 transition-colors">Переваги</a>
            <a href="#services" class="hover:text-orange-500 transition-colors">Послуги</a>
            <a href="#contact" class="hover:text-orange-500 transition-colors">Бронь</a>
            <a href="#footer" class="hover:text-orange-500 transition-colors">Контакти</a>
        </nav>

        <button type="button" id="menu" aria-label="Меню" aria-expanded="false" aria-controls="mobileNav"
            class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-md hover:bg-zinc-900 transition-colors">
            <span class="block w-6 h-0.5 bg-white"></span>
            <span class="block w-6 h-0.5 bg-white"></span>
            <span class="block w-6 h-0.5 bg-white"></span>
        </button>
    </div>

    <nav id="mobileNav" class="md:hidden hidden flex-col gap-1 px-4 pb-4 border-t border-zinc-800 bg-black">
        <a href="#features" class="block px-3 py-3 text-sm font-medium hover:text-orange-500 hover:bg-zinc-900 rounded-md transition-colors">Переваги</a>
        <a href="#services" class="block px-3 py-3 text-sm font-medium hover:text-orange-500 hover:bg-zinc-900 rounded-md transition-colors">Послуги</a>
        <a href="#contact" class="block px-3 py-3 text-sm font-medium hover:text-orange-500 hover:bg-zinc-900 rounded-md transition-colors">Бронь</a>
        <a href="#footer" class="block px-3 py-3 text-sm font-medium hover:text-orange-500 hover:bg-zinc-900 rounded-md transition-colors">Контакти</a>
    </nav>
</header>
