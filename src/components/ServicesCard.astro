---
const { servicesTitle, image, alt, servicesText } = Astro.props;

import { Image } from 'astro:assets';
import '../styles/global.css';
---

<article class="group bg-zinc-900 rounded-2xl border border-zinc-800 hover:border-orange-500/50 transition-colors overflow-hidden flex flex-col h-full">
    <div class="p-5 pb-3">
        <h3 class="text-lg md:text-xl font-bold text-orange-500 leading-tight">{servicesTitle}</h3>
    </div>
    <Image src={image} alt={alt} loading="lazy"
        class="w-full h-48 object-cover" />
    <div class="p-5 pt-4 flex-1">
        <p class="text-sm text-zinc-300 leading-relaxed whitespace-pre-line">{servicesText}</p>
    </div>
</article>
