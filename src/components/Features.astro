---
import FeaturesCard from './FeaturesCard.astro';
import features1 from '../assets/images/features1.webp';
import features2 from '../assets/images/features2.webp';
import features3 from '../assets/images/features3.webp';

const features = [
    {
        title: "Встановлюй свої ігри!",
        image: features1,
        alt: "Встановлюй будь які ігри у нашому клубі",
        text: `У більшості клубів: «Грай у те, що вже є» 🙄 У нас:
«Хочеш Arena Breakout? Качай. Хочеш The Sims? Будь ласка. Навіть Farm Simulator — без проблем». Інтернет 1 Гігабіт → поки ти береш чіпси, гра вже завантажилась`,
    },
    {
        title: "Cyberhub запускає систему лояльності!",
        image: features2,
        alt: "Рівні лояльності доступні кожному",
        text: `Тепер кожна твоя гра — крок до постійної знижки.
Ми запустили прогресивну шкалу лояльності, яка рахує всі твої поповнення балансу за весь час і перетворює їх на знижки. Рівні лояльності:
🥉 Bronze — від 1000 грн ➡ 3% постійної знижки
🥈 Silver — від 2500 грн ➡ 5% постійної знижки
🥇 Gold — від 5000 грн ➡ 7% постійної знижки
💎 Platinum — від 10 000 грн ➡ 10% постійної знижки`,
    },
    {
        title: "Список доступних ігор!",
        image: features3,
        alt: "Список доступних ігор",
        text: `Тут для кожного є своя гра:
🎯 CS2 / Valorant / Apex / Call of Duty / Battlefield V / Battlefield 2042
⚔️ Dota 2 / LoL / Marvel Rivals
🚀 PUBG / Fortnite / Overwatch 2
💣 War Thunder / WoT / Crossout / Star Wars: Battlefront II
👾 Roblox / TF2 / CS 1.6
🌆 Cyberpunk / STALKER 2 / The Witcher 3: Wild Hunt
🔋 Залізо не підведе. Пінг — найнижчий.`,
    },
];
---
<section class="bg-black py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <h2 id="features" class="text-3xl md:text-4xl font-extrabold tracking-tight text-center mb-10 md:mb-14">
            Наші <span class="text-orange-500">переваги</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6
                    md:[&>*:last-child]:col-span-2 md:[&>*:last-child]:max-w-md md:[&>*:last-child]:justify-self-center
                    lg:[&>*:last-child]:col-span-1 lg:[&>*:last-child]:max-w-none lg:[&>*:last-child]:justify-self-stretch">
            {features.map((f) => (
                <FeaturesCard
                    featuresTitle={f.title}
                    featuresText={f.text}
                    image={f.image}
                    alt={f.alt}
                />
            ))}
        </div>
    </div>
</section>
